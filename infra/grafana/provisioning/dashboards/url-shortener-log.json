{
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["url-shortener"],
      "title": "URL Shortener (Metrics)",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📊 Log Overview",
      "type": "row"
    },
    {
      "title": "Log Volume by Level",
      "description": "How many log lines per second, grouped by level.\n\nHealthy pattern: info dominates, occasional warn, rare error.\nIf error volume spikes or matches info volume — something is very wrong.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "lines/s",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warn" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "debug" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({app=\"url-shortener\"} | json [$__auto]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Count",
      "description": "Total error logs in selected time range. Should be 0 in a healthy system.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 2,
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"] },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "count_over_time({app=\"url-shortener\", level=\"error\"} [$__auto])",
          "legendFormat": "errors",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Warn Count",
      "description": "Total warning logs. Warnings are usually client errors (bad input, 404s) — not urgent but worth monitoring for trends.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 3,
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"] },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "count_over_time({app=\"url-shortener\", level=\"warn\"} [$__auto])",
          "legendFormat": "warnings",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate vs Request Rate",
      "description": "Compares error log rate against total request log rate.\nIf the two lines converge — nearly every request is failing.",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 5 },
      "id": 4,
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "errors" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "requests" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "count_over_time({app=\"url-shortener\"} | json | msg=`request started` [$__auto])",
          "legendFormat": "requests",
          "refId": "A"
        },
        {
          "expr": "count_over_time({app=\"url-shortener\", level=\"error\"} [$__auto])",
          "legendFormat": "errors",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 200,
      "title": "🔥 Errors & Warnings",
      "type": "row"
    },
    {
      "title": "Top Error Messages",
      "description": "Most frequent error messages. Helps prioritize which errors to fix first — the one appearing 500 times matters more than the one appearing twice.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Count" },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "msg" },
            "properties": [
              { "id": "displayName", "value": "Error Message" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      },
      "targets": [
        {
          "expr": "sum by (msg) (count_over_time({app=\"url-shortener\", level=\"error\"} | json [$__auto]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] }
        }
      ]
    },
    {
      "title": "Top Warning Messages",
      "description": "Most frequent warnings. Typically validation failures and 404s. A sudden spike in a specific warning may indicate a client-side bug or an attack.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Count" },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "msg" },
            "properties": [
              { "id": "displayName", "value": "Warning Message" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      },
      "targets": [
        {
          "expr": "sum by (msg) (count_over_time({app=\"url-shortener\", level=\"warn\"} | json [$__auto]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] }
        }
      ]
    },
    {
      "title": "Recent Error Logs",
      "description": "Live stream of error logs. Each line includes request_id — click to expand and see full context.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{app=\"url-shortener\", level=~\"error|warn\"} | json",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 300,
      "title": "🌐 HTTP Request Logs",
      "type": "row"
    },
    {
      "title": "Requests by Status Code (from logs)",
      "description": "HTTP status code distribution derived from log lines.\n\nThis complements the Prometheus 'Error Rate by Status Code' panel — Prometheus shows rate, this shows volume from log perspective.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "id": 8,
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (status) (count_over_time({app=\"url-shortener\"} | json | msg=`request completed` | status != `` [$__auto]))",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests by Path",
      "description": "Which endpoints are getting hit the most.\nUseful for spotting unexpected traffic patterns — e.g., a bot hammering a specific endpoint.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "id": 9,
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (path) (count_over_time({app=\"url-shortener\"} | json | msg=`request started` | path != `` [$__auto]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Slowest Requests (> 500ms)",
      "description": "Requests that took longer than 500ms to complete.\nCorrelate with Prometheus latency percentiles — this panel shows the ACTUAL slow requests with full context (request_id, path, status).",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 37 },
      "id": 10,
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{app=\"url-shortener\"} | json | msg=`request completed` | duration > 500ms",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "id": 400,
      "title": "🔍 Log Search",
      "type": "row"
    },
    {
      "title": "All Logs (filterable)",
      "description": "Full log stream. Use the search bar above to filter.\n\nUseful queries to try in Explore:\n• Find a specific request: {app=\"url-shortener\"} | json | request_id=\"<id>\"\n• Cache failures: {app=\"url-shortener\"} | json | msg=~\".*cache.*\"\n• DB errors: {app=\"url-shortener\"} | json | msg=~\".*database.*|.*DB.*\"",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 46 },
      "id": 11,
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{app=\"url-shortener\"} | json",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["url-shortener", "logs", "loki"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "name": "DS_LOKI",
        "query": "loki",
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "URL Shortener — Logs",
  "uid": "url-shortener-logs",
  "version": 1
}