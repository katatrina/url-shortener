    {
      "title": "Cache Hit Ratio (%)",
      "description": "Percentage of cache lookups that found the URL in Redis. Target: > 80%.",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 18
      },
      "id": 6,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "rate(urlshortener_cache_requests_total{job=\"url-shortener\", result=\"hit\"}[5m]) / (rate(urlshortener_cache_requests_total{job=\"url-shortener\", result=\"hit\"}[5m]) + rate(urlshortener_cache_requests_total{job=\"url-shortener\", result=\"miss\"}[5m])) * 100",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cache Hit vs Miss (req/s)",
      "description": "Cache lookup rate by result. Green (hits) should dominate red (misses).",
