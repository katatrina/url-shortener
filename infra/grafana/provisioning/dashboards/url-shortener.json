            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "rate(urlshortener_cache_errors_total[5m])",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ]
    },
