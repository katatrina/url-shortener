          "legendFormat": "in-flight",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate by Status Code",
      "description": "HTTP 4xx/5xx responses per second. 4xx = bad input or expired URLs. 5xx = server-side failure.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 9
      },
      "id": 4,
